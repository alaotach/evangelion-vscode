  "tokenColors": [
    {
      "scope": ["comment"],
      "settings": { "foreground": "#2d0044", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#7b2fbe", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control"],
      "settings": { "foreground": "#c678ff" }
    },
    {
      "scope": ["string"],
      "settings": { "foreground": "#a8ff3e" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#f5c518" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#c678ff" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#a8ff3e" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#7b2fbe", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": { "foreground": "#f5c518", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#7b2fbe" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#7b2fbe" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#f5c518" }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#c678ff" }
    },
    {
      "scope": ["constant", "constant.language"],
      "settings": { "foreground": "#f5c518" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#3d0066" }
