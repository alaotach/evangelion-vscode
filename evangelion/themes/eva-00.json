  "tokenColors": [
    {
      "scope": ["comment"],
      "settings": { "foreground": "#2F4F6F", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#2F6FA3", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control"],
      "settings": { "foreground": "#5DADE2" }
    },
    {
      "scope": ["string"],
      "settings": { "foreground": "#81D4FA" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#E6F1F7" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#4FC3F7" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#2F6FA3" }
    },
    {
      "scope": ["entity.name.class"],
      "settings": { "foreground": "#81D4FA", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#2F6FA3" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#5DADE2" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#81D4FA" }
    },
    {
      "scope": ["constant", "constant.language"],
      "settings": { "foreground": "#E6F1F7" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#2F4F6F" }
    }
  ]
}