  "tokenColors": [
    {
      "scope": ["comment"],
      "settings": { "foreground": "#3a0a00", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#cc3300", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.control"],
      "settings": { "foreground": "#ff2244" }
    },
    {
      "scope": ["string"],
      "settings": { "foreground": "#ffaa00" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#ff6600" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#cc3300" }
    },
    {
      "scope": ["entity.name.class"],
      "settings": { "foreground": "#ffaa00", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#cc3300" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#ff2244" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ffaa00" }
    },
    {
      "scope": ["constant", "constant.language"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#3a0a00" }
    }
  ]
}