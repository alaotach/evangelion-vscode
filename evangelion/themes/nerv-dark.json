  "tokenColors": [
    {
        "scope": ["comment"],
        "settings": { "foreground": "#004433", "fontStyle": "italic" }
    },
    {
        "scope": ["keyword", "storage.type", "storage.modifier"],
        "settings": { "foreground": "#00FFCC", "fontStyle": "bold" }
    },
    {
        "scope": ["string"],
        "settings": { "foreground": "#00FF88" }
    },
    {
        "scope": ["constant.numeric"],
        "settings": { "foreground": "#FFAA00" }
    },
    {
        "scope": ["entity.name.function"],
        "settings": { "foreground": "#00FFCC" }
    },
    {
        "scope": ["variable"],
        "settings": { "foreground": "#00CC66" }
    },
    {
        "scope": ["entity.name.class"],
        "settings": { "foreground": "#00FF88", "fontStyle": "bold" }
    },
    {
        "scope": ["keyword.operator"],
        "settings": { "foreground": "#FFAA00" }
    }
    ]
}